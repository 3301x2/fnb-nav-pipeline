# retail_cdao/.env.example
# Copy this file to retail_cdao/.env and fill in real values.
# .env is gitignored — credentials never leave your machine.

# ── AD credentials for SFTP into avalonwinscp.fnb.co.za ──────────────────────
AD_USERNAME=f3799182
AD_PASSWORD=your-ad-password-here

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT=fmn-sandbox

# Production bucket — where the real monthly upload goes
GCP_BUCKET=customer_spend_data

# Test bucket — used when you pass --test to pierre_monthly_run.sh
# Put whatever the actual test bucket is named here.
TEST_BUCKET=customer_spend_data_test

# ── Optional overrides ───────────────────────────────────────────────────────
# SFTP_HOST=avalonwinscp.fnb.co.za
# REMOTE_DIR=/data/fnb/retail_sales_and_cdao/Pierre/
# STEM=burger
